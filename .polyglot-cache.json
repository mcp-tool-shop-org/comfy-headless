  "entries": {
    "4580147accbb0302": {
      "translation": "आरामदायक, बिना सिर वाला.",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "477ac75c8409838f": {
      "translation": "\"कोम्फीयूआई की शक्ति को आसान तरीके से उपलब्ध कराना, ताकि इसकी जटिलताओं को कम किया जा सके।\"",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "9b9415275aa07a97": {
      "translation": "\"कॉम्फी हेडलेस\" क्यों?",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "f1c900f4a4d6cff1": {
      "translation": "समस्या।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "3eb45db8ea520f0d": {
      "translation": "समाधान।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "1a20fc4dc8ce3304": {
      "translation": "ज़रूर, मैं आपकी मदद कर सकता हूँ। कृपया वह अंग्रेजी पाठ प्रदान करें जिसका आप हिंदी में अनुवाद करवाना चाहते हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "3b88b43261c1c270": {
      "translation": "ज़रूर, मैं आपकी मदद कर सकता हूँ। कृपया वह अंग्रेजी पाठ प्रदान करें जिसका आप हिंदी में अनुवाद करवाना चाहते हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "18ef110c5d562912": {
      "translation": "कॉम्फीयूआई का नोड इंटरफ़ेस बहुत जटिल है।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "91fd8c013c7155c4": {
      "translation": "सरल पूर्व-निर्धारित सेटिंग्स और एक स्पष्ट पायथन एपीआई।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "6eb55a5890a443e8": {
      "translation": "\"प्रॉम्प्ट इंजीनियरिंग एक जटिल काम है।\"",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "1cfc594b7f845411": {
      "translation": "एआई-आधारित संकेत (प्रॉम्प्ट) को बेहतर बनाने की तकनीक।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "155f73ddfb400a84": {
      "translation": "वीडियो बनाना एक जटिल प्रक्रिया है।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "a49dcdacf84d1de4": {
      "translation": "एक पंक्ति वाला वीडियो, जिसमें मॉडल के लिए पहले से निर्धारित सेटिंग्स उपलब्ध हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "543084c19b517b91": {
      "translation": "मुझे नहीं पता कि कौन से सेटिंग्स (विकल्प) इस्तेमाल करने हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "0418663045e1f946": {
      "translation": "आपके इरादे के लिए सबसे उपयुक्त सेटिंग्स, स्वचालित रूप से।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "abb619d8b0588257": {
      "translation": "शुरुआत कैसे करें।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "b1bb69a311945b59": {
      "translation": "दर्शनशास्त्र।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "c7aa5d548dbe32a1": {
      "translation": "- **उपयोगकर्ताओं के लिए:** सरल पूर्व-निर्धारित सेटिंग्स और एआई-संचालित संकेत अनुकूलन।\n- **डेवलपर्स के लिए:** स्वच्छ एपीआई (API) और टेम्पलेट-आधारित वर्कफ़्लो संकलन।\n- **सभी के लिए:** आपकी आवश्यकताओं के अनुसार सर्वोत्तम सेटिंग्स, जो स्वचालित रूप से लागू हो जाएंगी।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "ed383afd27175535": {
      "translation": "स्थापना।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "5da8da0e389121b7": {
      "translation": "मॉड्यूलर इंस्टॉलेशन (संस्करण 2.5.0 और उसके बाद के संस्करणों में)",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "e20ab67fcd43fdee": {
      "translation": "केवल वही चीजें स्थापित करें जिनकी आपको आवश्यकता है:",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "37e83c513f435c53": {
      "translation": "उपलब्ध अतिरिक्त सुविधाएँ।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "fbd9c4fbd8ab97fb": {
      "translation": "निर्भरताएँ।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "d0bfd0df3ecd0d7f": {
      "translation": "विशेषताएं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "6da5100c388f6595": {
      "translation": "\"The quick brown fox jumps over the lazy dog.\"\n\n\"यह फुर्तीला भूरा लोमड़ी आलसी कुत्ते के ऊपर से कूदता है।\"",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "c7836a7b7798edb5": {
      "translation": "ज़रूर, मैं आपकी मदद कर सकता हूँ। कृपया वह अंग्रेजी पाठ प्रदान करें जिसका आप हिंदी में अनुवाद करवाना चाहते हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "9efb65c8a640ff8a": {
      "translation": "ओलामा: प्रॉम्प्ट इंटेलिजेंस (Ollama: प्रॉम्प्ट इंटेलिजेंस)",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "5785eb8dbf54f714": {
      "translation": "वेब सॉकेट।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "a829a50e7a860373": {
      "translation": "वास्तविक समय में प्रगति की जानकारी।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "25e83924042d2f44": {
      "translation": "psutil एक पायथन लाइब्रेरी है जो सिस्टम की जानकारी और संसाधनों को प्रबंधित करने में मदद करती है।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "e2e4070fee812c07": {
      "translation": "सिस्टम की स्वास्थ्य निगरानी।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "3cbc2376704aefb1": {
      "translation": "ग्रैडियो",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "e4285706d3f62291": {
      "translation": "वेब इंटरफेस।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "66cb2d5d957afeaa": {
      "translation": "पायडैंटिक।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "a0da5816d48dd76c": {
      "translation": "कॉन्फ़िगरेशन की वैधता की जांच।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "e4b2362aa5d161b7": {
      "translation": "ओपनटेलमेट्री (OpenTelemetry)",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "84a51e3edeace7ae": {
      "translation": "वितरित ट्रेसिंग।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "5fdc05f1cc3b69d1": {
      "translation": "एआई (कृत्रिम बुद्धिमत्ता) + वेबसॉकेट।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "069ec31ad11cc4d6": {
      "translation": "अनुशंसित पैकेज।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "0b9a591886938278": {
      "translation": "उपरोक्त सभी।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "13cc2ed3eac469aa": {
      "translation": "सब कुछ।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "1960f0711b88c994": {
      "translation": "आवश्यकताएं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "279eb045d989abfe": {
      "translation": "- पायथन 3.10 या उससे ऊपर का संस्करण\n- कॉमफीयूआई स्थानीय रूप से चल रहा होना चाहिए (डिफ़ॉल्ट: `http://localhost:8188`)\n- वैकल्पिक: एआई प्रॉम्प्ट को बेहतर बनाने के लिए ओलामा का उपयोग किया जा सकता है।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "98a2f8cba1b36eff": {
      "translation": "उपयोग.",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "83b3af66531c2ff4": {
      "translation": "इसका उपयोग पुस्तकालय के रूप में करें।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "ae7a049811dd3d7a": {
      "translation": "एआई (कृत्रिम बुद्धिमत्ता) के साथ उन्नत।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "ef308421b59cb51c": {
      "translation": "वीडियो निर्माण।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "5efc1720ab91d738": {
      "translation": "वेब यूआई (Web UI) को शुरू करें।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "08f248f720a1efef": {
      "translation": "या फिर, कमांड लाइन के माध्यम से:",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "5bfa3339ad56bfc5": {
      "translation": "**यूआई विशेषताएं (संस्करण 2.5.1):**\n- **छवि निर्माण:** टेक्स्ट से छवि निर्माण (txt2img) जिसमें पूर्व-निर्धारित सेटिंग्स और एआई प्रॉम्प्ट एन्हांसमेंट शामिल हैं।\n- **वीडियो निर्माण:** एनिमेट डिफ, एलटीएक्स, हुनयुआन, वान का समर्थन।\n- **कतार और इतिहास:** वास्तविक समय में कतार प्रबंधन, कार्यों का इतिहास।\n- **वर्कफ़्लो:** वर्कफ़्लो टेम्पलेट्स को ब्राउज़ करें, आयात करें और बनाएं।\n- **मॉडल ब्राउज़र:** चेकपॉइंट, लोरा, मोशन मॉडल देखें।\n- **सेटिंग्स:** कनेक्शन प्रबंधन, टाइमआउट, सिस्टम जानकारी।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "d03f7aa7959f91c8": {
      "translation": "**विषय:** समुद्री धुंध - हल्के नीले-हरे रंग की बारीकियां, जो गर्म, तटस्थ पृष्ठभूमि पर दिखाई देती हैं।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "42ba247518c5d677": {
      "translation": "वीडियो मॉडल (संस्करण 2.5.0)",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "27a3048957fdd8ec": {
      "translation": "समर्थित मॉडल।",
      "model": "translategemma:12b",
      "timestamp": 1772021434605
    },
    "af4b9c14b40df728": {
